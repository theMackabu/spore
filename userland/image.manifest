# source baked-path
#
# Placement follows the invoker:
# - /bin is for human-interactive tools in PATH.
# - /libexec/spore-test is for regression instruments invoked by test harnesses.
# - /home/spore/demos is for curiosity/demo fixtures.
dir /home
dir /root
dir /etc/mycelium
dir /sbin
dir /libexec/spore-test
dir /lib/mycelium
dir /run/mycelium
dir /var/log
dir /var/lib/mycelium
dir /etc/update-motd.d

userland/bin/init /lib/mycelium/init
symlink /lib/mycelium/init /sbin/init
userland/bin/myc /lib/mycelium/myc
symlink /lib/mycelium/myc /sbin/myc
userland/bin/msh /bin/msh
userland/bin/dash /bin/dash
symlink msh /bin/sh

userland/bin/shutdown /bin/shutdown
userland/bin/reboot /bin/reboot
userland/bin/ls /bin/ls
userland/bin/cat /bin/cat
userland/bin/echo /bin/echo
userland/bin/clear /bin/clear
userland/bin/file /bin/file
userland/bin/stat /bin/stat
userland/bin/uname /bin/uname
userland/bin/edit /bin/edit
userland/bin/pico /bin/pico
