diff --git a/src/io_url_wget.c b/src/io_url_wget.c
--- a/src/io_url_wget.c
+++ b/src/io_url_wget.c
@@ -14,12 +14,67 @@
 #include <errno.h>
 #include <fcntl.h>
 #include <unistd.h>
+#include <stdlib.h>
 
 static char wget_timeout[16];
 static bool wget_no_check_certificate;
 static struct apk_out *wget_out;
 static unsigned int wget_fetch_seq;
 
+struct wget_istream {
+	struct apk_istream is;
+	struct apk_istream *inner;
+	char tmp[96];
+};
+
+static void wget_is_get_meta(struct apk_istream *is, struct apk_file_meta *meta)
+{
+	struct wget_istream *wis = container_of(is, struct wget_istream, is);
+	apk_istream_get_meta(wis->inner, meta);
+}
+
+static ssize_t wget_is_read(struct apk_istream *is, void *ptr, size_t size)
+{
+	struct wget_istream *wis = container_of(is, struct wget_istream, is);
+	return apk_istream_read_max(wis->inner, ptr, size);
+}
+
+static int wget_is_close(struct apk_istream *is)
+{
+	struct wget_istream *wis = container_of(is, struct wget_istream, is);
+	int r = apk_istream_close_error(wis->inner, is->err);
+	unlink(wis->tmp);
+	free(wis);
+	return r;
+}
+
+static const struct apk_istream_ops wget_istream_ops = {
+	.get_meta = wget_is_get_meta,
+	.read = wget_is_read,
+	.close = wget_is_close,
+};
+
+static struct apk_istream *wget_istream_from_tempfile(const char *tmp)
+{
+	struct apk_istream *inner = apk_istream_from_file(AT_FDCWD, tmp);
+	if (IS_ERR(inner)) return inner;
+
+	struct wget_istream *wis = calloc(1, sizeof(*wis) + apk_io_bufsize);
+	if (!wis) {
+		apk_istream_close(inner);
+		unlink(tmp);
+		return ERR_PTR(-ENOMEM);
+	}
+	wis->is.ops = &wget_istream_ops;
+	wis->is.buf = (uint8_t *)(wis + 1);
+	wis->is.buf_size = apk_io_bufsize;
+	wis->is.ptr = (uint8_t *)(wis + 1);
+	wis->is.end = (uint8_t *)(wis + 1);
+	wis->inner = inner;
+	apk_fmt(wis->tmp, sizeof wis->tmp, "%s", tmp);
+	return &wis->is;
+}
+
 struct apk_istream *apk_io_url_istream(const char *url, time_t since)
 {
 	char *argv[16];
@@ -58,5 +99,5 @@ struct apk_istream *apk_io_url_istream(const char *url, time_t since)
 		unlink(tmp);
 		return ERR_PTR(r);
 	}
-	return apk_istream_from_file(AT_FDCWD, tmp);
+	return wget_istream_from_tempfile(tmp);
 }
