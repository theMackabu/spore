+static int spore_write_full(int fd, const void *buf, size_t len)
+{
+  const unsigned char *p = (const unsigned char *)buf;
+  while(len) {
+    ssize_t n = write(fd, p, len);
+    if(n < 0 && errno == EINTR)
+      continue;
+    if(n <= 0)
+      return -1;
+    p += (size_t)n;
+    len -= (size_t)n;
+  }
+  return 0;
+}
+
+static int spore_read_full(int fd, void *buf, size_t len)
+{
+  unsigned char *p = (unsigned char *)buf;
+  while(len) {
+    ssize_t n = read(fd, p, len);
+    if(n < 0 && errno == EINTR)
+      continue;
+    if(n <= 0)
+      return -1;
+    p += (size_t)n;
+    len -= (size_t)n;
+  }
+  return 0;
+}
+
+static int spore_trustd_connect(void)
+{
+  int fd = socket(AF_UNIX, SOCK_STREAM, 0);
+  struct sockaddr_un addr;
+  if(fd < 0)
+    return -1;
+  memset(&addr, 0, sizeof(addr));
+  addr.sun_family = AF_UNIX;
+  strcpy(addr.sun_path, "/run/trustd.sock");
+  if(connect(fd, (struct sockaddr *)&addr, sizeof(addr)) != 0) {
+    close(fd);
+    return -1;
+  }
+  return fd;
+}
+
+static bool spore_trustd_available(void)
+{
+  int fd = spore_trustd_connect();
+  if(fd < 0)
+    return FALSE;
+  close(fd);
+  return TRUE;
+}
+
+static int spore_trustd_verify(const char *hostname,
+                               const mbedtls_x509_crt *chain,
+                               uint32_t *verify_flags)
+{
+  uint32_t magic = 0x31525453u;
+  uint32_t host_len;
+  uint32_t cert_count = 0;
+  uint32_t reply_magic = 0;
+  int32_t rc = -1;
+  int fd = spore_trustd_connect();
+  const mbedtls_x509_crt *cur;
+
+  if(fd < 0 || !hostname || !chain)
+    goto out;
+  host_len = (uint32_t)strlen(hostname);
+  for(cur = chain; cur; cur = cur->next)
+    ++cert_count;
+  if(host_len == 0 || host_len > 255 || cert_count == 0 || cert_count > 12)
+    goto out;
+
+  if(spore_write_full(fd, &magic, sizeof(magic)) != 0 ||
+     spore_write_full(fd, &host_len, sizeof(host_len)) != 0 ||
+     spore_write_full(fd, hostname, host_len) != 0 ||
+     spore_write_full(fd, &cert_count, sizeof(cert_count)) != 0)
+    goto out;
+
+  for(cur = chain; cur; cur = cur->next) {
+    uint32_t cert_len = (uint32_t)cur->raw.len;
+    if(cert_len == 0 || cert_len > 65536)
+      goto out;
+    if(spore_write_full(fd, &cert_len, sizeof(cert_len)) != 0 ||
+       spore_write_full(fd, cur->raw.p, cert_len) != 0)
+      goto out;
+  }
+
+  if(spore_read_full(fd, &reply_magic, sizeof(reply_magic)) != 0 ||
+     spore_read_full(fd, &rc, sizeof(rc)) != 0 ||
+     spore_read_full(fd, verify_flags, sizeof(*verify_flags)) != 0 ||
+     reply_magic != 0x54525350u)
+    rc = -1;
+
+out:
+  if(fd >= 0)
+    close(fd);
+  return rc;
+}
 
